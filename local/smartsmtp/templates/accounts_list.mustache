{{!
  @template local_smartsmtp/accounts_list
  Lista de buzones SMTP configurados.
  Variables: accounts (array), can_add (bool)
}}
<div class="local-smartsmtp-accounts">

  {{#can_add}}
  <div class="mb-3">
    <a href="{{add_url}}" class="btn btn-primary">
      {{#str}} add_account, local_smartsmtp {{/str}}
    </a>
  </div>
  {{/can_add}}

  {{#accounts}}
  <div class="card mb-2">
    <div class="card-body d-flex align-items-center justify-content-between">
      <div>
        <strong>{{name}}</strong>
        <span class="text-muted ml-2">{{host}}:{{port}}</span>
        {{#is_default}}
          <span class="badge badge-primary ml-2">
            {{#str}} default, local_smartsmtp {{/str}}
          </span>
        {{/is_default}}
        {{^enabled}}
          <span class="badge badge-secondary ml-2">
            {{#str}} disabled, local_smartsmtp {{/str}}
          </span>
        {{/enabled}}
      </div>
      <div class="d-flex gap-2">
        <span class="text-muted small mr-3">
          {{daily_count}} / {{daily_limit}}
          {{#str}} emails_today, local_smartsmtp {{/str}}
        </span>
        <a href="{{test_url}}" class="btn btn-sm btn-outline-secondary">
          {{#str}} test_connection, local_smartsmtp {{/str}}
        </a>
        <a href="{{edit_url}}" class="btn btn-sm btn-outline-primary">
          {{#str}} edit {{/str}}
        </a>
        <a href="{{delete_url}}" class="btn btn-sm btn-outline-danger"
           data-confirmation="{{#str}} confirm_delete, local_smartsmtp {{/str}}">
          {{#str}} delete {{/str}}
        </a>
      </div>
    </div>
  </div>
  {{/accounts}}

  {{^accounts}}
  <div class="alert alert-info">
    {{#str}} no_accounts_yet, local_smartsmtp {{/str}}
  </div>
  {{/accounts}}

</div>